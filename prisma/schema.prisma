generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id       String    @id
  name     String
  email    String    @unique
  phone    String    @unique
  comments Comment[]
  likes    Like[]
  wallet   Wallet?
  loves    Product[] @relation("loves")

  @@map("customers")
}

model Product {
  id       String     @id
  name     String
  price    Int
  stock    Int
  category String
  likedBy  Like[]
  lovedBy  Customer[] @relation("loves")

  @@map("products")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  @@map("categories")
}

model Wallet {
  id          String   @id
  balance     Int
  customer_id String   @unique
  customer    Customer @relation(fields: [customer_id], references: [id])

  @@map("wallet")
}

model Comment {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  customer_id String   @db.VarChar(100)
  customer    Customer @relation(fields: [customer_id], references: [id], map: "customer_to_comment_fk")

  @@index([customer_id], map: "customer_to_comment_fk")
  @@map("comments")
}

model Like {
  customer_id String
  product_id  String
  customer    Customer @relation(fields: [customer_id], references: [id])
  product     Product  @relation(fields: [product_id], references: [id])

  @@id([customer_id, product_id])
  @@index([product_id], map: "likes_product_id_fkey")
  @@map("likes")
}

model sample {
  id   String @id
  name String
}

model categories {
  id Int @id @default(autoincrement())
  name String
}

model comments{
  id Int @id @default(autoincrement())
  title String @db.VarChar(200)
  description String? @db.Text
  customer_id String @db.VarChar(100)
  customers customers @relation(fields: [customer_id], references: [id], map:"customer_to_comment_fk"),
  @@index([customer_id], map:"customer_to_comment_fk")
}
